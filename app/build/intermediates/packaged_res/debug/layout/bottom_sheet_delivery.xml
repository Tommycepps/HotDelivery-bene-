<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Handle bar decorativa -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#CCCCCC"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_delivery_nome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome Delivery"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_delivery_descrizione"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descrizione"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_delivery_distanza"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Distanza: --"
        android:textSize="16sp"
        android:textColor="#FF6F00"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_delivery_aggiornato"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aggiornato: --"
        android:textSize="12sp"
        android:textColor="#999999" />

</LinearLayout>
